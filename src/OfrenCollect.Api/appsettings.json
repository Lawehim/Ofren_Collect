{
  "Jwt": {
    "Issuer": "ofren-collect",
    "Audience": "ofren-collect-api",
    "AccessTokenMinutes": 60
  },
  "Monnify": {
    "BaseUrl": "https://sandbox.monnify.com",
    "VerifyWebhookSignature": true
  },
  "Cors": {
    "Origin": "http://localhost:5173"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
