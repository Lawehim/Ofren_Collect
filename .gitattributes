# Normalize line endings — LF in the repo, checked out native.
* text=auto

*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.slnx      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.html      text eol=lf
*.css       text eol=lf

# Binary assets
*.pdf       binary
*.png       binary
*.jpg       binary
*.ico       binary
