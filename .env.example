# ---------------------------------------------------------------------------
# Ofren Collect — example configuration.
# Copy the relevant values into .NET user-secrets (local) or environment
# variables. NEVER put real secrets in this file or any committed file.
# See CLAUDE.md §9 and the README for the user-secrets commands.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
ConnectionStrings__OfrenDb=Host=localhost;Port=5432;Database=ofren_collect;Username=ofren;Password=CHANGE_ME

# --- JWT signing (secret; use a long random value) ---
Jwt__Issuer=ofren-collect
Jwt__Audience=ofren-collect-api
Jwt__SigningKey=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
Jwt__AccessTokenMinutes=60

# --- Monnify sandbox (secret; obtain from your Monnify dashboard) ---
Monnify__BaseUrl=https://sandbox.monnify.com
Monnify__ApiKey=CHANGE_ME
Monnify__SecretKey=CHANGE_ME
Monnify__ContractCode=CHANGE_ME

# --- AI assistant (optional; disabled by default) ---
# Provider-agnostic: point BaseUrl at ANY OpenAI-compatible chat-completions endpoint.
# The model only classifies a question into a fixed intent — it never sees your data.
#
# Free hosted option (works from Render) — Groq (free key at https://console.groq.com):
#   Ai__Enabled=true
#   Ai__BaseUrl=https://api.groq.com/openai
#   Ai__Model=llama-3.1-8b-instant
#   Ai__ApiKey=CHANGE_ME            # secret — keep out of committed files
#
# Free local option (dev only; NOT reachable from Render) — Ollama:
#   Ai__Enabled=true
#   Ai__BaseUrl=http://localhost:11434
#   Ai__Model=llama3.2
#   (no ApiKey needed for local Ollama)
Ai__Enabled=false

# --- Refunds (FR-11; Owner-only, disabled by default) ---
# Enable the refund endpoint once the Monnify refund endpoint path is confirmed in the sandbox.
Refunds__Enabled=false
